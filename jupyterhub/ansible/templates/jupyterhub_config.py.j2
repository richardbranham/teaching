log = logging.getLogger("jupyterhub")

uid = 1000
gid = 100

class GwinnettDockerSpawner(DockerSpawner):

  async def start(self):

      storage_name = self.user.escaped_name

      user_home = (
          f"/srv/jupyterhub/users/{storage_name}"
      )

      log_dir = (
          f"/srv/jupyterhub/users/{storage_name}/logs"
      )

      working_copy = (
          f"{user_home}/CIST1220/midterm_files_working_copy"
      )

      master_dir = (
          "/srv/jupyterhub/CIST1220/midterm_files_master"
      )

      os.makedirs(
          os.path.dirname(working_copy),
          exist_ok=True
      )

      os.makedirs(
          log_dir,
          exist_ok=True
      )
      os.chown(log_dir, uid, gid)

      #if not os.path.exists(working_copy):
      if (
          not os.path.exists(working_copy)
          or len(os.listdir(working_copy)) == 0
      ):

          shutil.copytree(
              master_dir,
              working_copy
          )

          for root, dirs, files in os.walk(working_copy):

              os.chown(root,1000,100)
              os.chmod(root,0o755)

              for d in dirs:
                  path=os.path.join(root,d)
                  os.chown(path,1000,100)
                  os.chmod(path,0o755)

              for f in files:
                  path=os.path.join(root,f)
                  os.chown(path,1000,100)
                  os.chmod(path,0o644)

      self.volumes = {

          user_home:
              "/home/jovyan",

          master_dir: {
              "bind":
                  "/home/jovyan/CIST1220/midterm_files_master",
              "mode":
                  "ro"
          },

          working_copy: {
              "bind":
                  "/home/jovyan/CIST1220/midterm_files_working_copy",
              "mode":
                  "rw"
          },

          log_dir: {
              "bind":
                  "/var/log/jupyter",
              "mode":
                  "rw"
          }
      }

      self.args = (self.args or []) + [
          f"--ServerApp.log_file=/var/log/jupyter/jupyter.log"
      ]

      result = await super().start()

      log.info(
          f"User '{self.user.name}' container started: "
          f"name='{self.name}' id='{self.container_id}'"
      )

      return result

class GwinnettTechAuthenticator(NativeAuthenticator):

    def normalize_username(self, username):
        return username.lower().strip()

    def validate_username(self, username):
        username = username.lower().strip()
        return (
            username.endswith("@gwinnetttech.edu")
            or username.endswith("@student.gwinnetttech.edu")
        )

    async def pre_spawn_start(self, user, spawner):
        db = self.db

        userinfo = db.query(UserInfo).filter(
            UserInfo.username == user.name
        ).first()

        if userinfo and getattr(userinfo, "must_change_password", False):
            raise web.HTTPError(
                403,
                "Password change required"
            )
            
            
    def post_save_password(self, userinfo):
        userinfo.is_must_change_password = False

